#!/usr/bin/env bash
set -euo pipefail

TB="${1:?usage: ./vlt tb/<test>.sv <top_module>}"
TOP="${2:?usage: ./vlt tb/<test>.sv <top_module>}"

COMMON_FLAGS=(
  -sv --binary --timing
  -Wno-fatal
  -Wno-TIMESCALEMOD -Wno-WIDTHTRUNC -Wno-WIDTHEXPAND -Wno-DECLFILENAME
  -Wno-GENUNNAMED -Wno-VARHIDDEN -Wno-PROCASSINIT -Wno-UNUSEDSIGNAL
  -Wno-UNOPTFLAT -Wno-UNSIGNED -Wno-UNDRIVEN -Wno-LATCH
  -IHardFloat/source -IHardFloat/source/8086-SSE
)

COMMON_SRCS=(
  HardFloat/source/HardFloat_primitives.v
  HardFloat/source/HardFloat_consts.vi
  HardFloat/source/HardFloat_localFuncs.vi
  HardFloat/source/HardFloat_rawFN.v
  HardFloat/source/addRecFN.v
  HardFloat/source/compareRecFN.v
  HardFloat/source/divSqrtRecFN_small.v
  HardFloat/source/fNToRecFN.v
  HardFloat/source/iNToRecFN.v
  HardFloat/source/isSigNaNRecFN.v
  HardFloat/source/mulAddRecFN.v
  HardFloat/source/mulRecFN.v
  HardFloat/source/recFNToFN.v
  HardFloat/source/recFNToIN.v
  HardFloat/source/recFNToRecFN.v
  HardFloat/source/8086-SSE/HardFloat_specialize.v

  rtl/hf_mac32.sv
  rtl/activation_relu32.sv
  rtl/nc_neuralcomputer.sv
)

DPI="$PWD/tb/dpi_casts.cc"

verilator "${COMMON_FLAGS[@]}" \
  "${COMMON_SRCS[@]}" \
  "$TB" \
  --top-module "$TOP" \
  --exe "$DPI"

"./obj_dir/V${TOP}"
